NODE_ENV=development
HOST=0.0.0.0
PORT=5000

# Comma-separated browser origins allowed for CORS (no URL shortening — full origins only).
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Canonical public URL of this API (HTTPS, no trailing slash). Used in JSON responses — never hardcode hostnames in code.
# PUBLIC_URL=https://your-api.onrender.com
# Alias: BACKEND_PUBLIC_URL (same meaning).

# Max JSON body size for OCR uploads etc.
# JSON_BODY_LIMIT=15mb

SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key_or_service_role
JWT_SECRET=set_a_long_random_secret

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
AI_PROMPT_MAX_CHARS=12000

FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
# Production / Render: paste the entire Firebase service account JSON as one line (Render secret).
# Optional locally if you use GOOGLE_APPLICATION_CREDENTIALS to a file instead.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
